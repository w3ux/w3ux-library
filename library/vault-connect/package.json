{
	"name": "@w3ux/vault-connect-source",
	"description": "Polkadot Vault (QR-based) wallet adaptor for @w3ux/react-connect-kit",
	"version": "1.0.0",
	"license": "GPL-3.0-only",
	"type": "module",
	"keywords": [
		"w3ux",
		"polkadot",
		"vault",
		"qrcode",
		"web3",
		"react",
		"typescript"
	],
	"homepage": "https://w3ux.org/library/vault-connect/overview",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/w3ux/w3ux-library.git",
		"directory": "library/vault-connect"
	},
	"bugs": {
		"url": "https://github.com/w3ux/w3ux-library/issues"
	},
	"scripts": {
		"clear": "rm -rf node_modules dist tsconfig.tsbuildinfo",
		"check": "biome check .",
		"lint": "biome check --write .",
		"build": "tsup",
		"compile": "builder -t vault-connect"
	},
	"dependencies": {
		"html5-qrcode": "^2.3.8",
		"qrcode-generator": "1.5.0",
		"styled-components": "^6.3.12",
		"xxhash-wasm": "^1.0.2"
	},
	"devDependencies": {
		"@types/react": "^19",
		"@w3ux/observables-connect": "workspace:*",
		"builder": "workspace:*",
		"react": "^19",
		"tsup": "^8"
	},
	"peerDependencies": {
		"dedot": "^1",
		"@w3ux/react-connect-kit": "^4"
	}
}
